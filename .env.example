# Clerk Authentication
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_JWKS_URL=https://clerk.com/.well-known/jwks.json

# Database
DATABASE_URL=postgresql://launchpad:password@localhost:5432/launchpad

# Redis
REDIS_URL=redis://localhost:6379

# Object Storage (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=arishem-reports
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Alerts
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=re_xxxxxxxxx  # Get your API key from https://resend.com

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:3000/api/integrations/github/callback

# App
APP_URL=http://localhost:8080

# Security and Limits
MAX_RUNS_PER_DAY=10
EXPECTS_UNSAFE_CODE=false

# MAx turn budget
MAX_TURN=10